generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  resetToken       String?
  resetTokenExpiry DateTime?

  profileImage String?

  role         String        @default("patient")
  isVerified   Boolean       @default(false)
  appointments Appointment[]
  reviews      Review[]
  createdAt    DateTime      @default(now())
}

model Doctor {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  resetToken       String?
  resetTokenExpiry DateTime?

  profileImage String?
  licenseUrl   String?

  role String @default("doctor")

  specialization       String
  availableStartTime   String
  availableEndTime     String
  consultationDuration Int
  isVerified           Boolean       @default(false)
  leaves               DoctorLeave[]

  appointments Appointment[]
  reviews      Review[]

  createdAt DateTime @default(now())
}

model Appointment {
  id String @id @default(uuid())

  patientId String
  doctorId  String

  appointmentDate DateTime

  slotStartTime String?
  slotEndTime   String?

  queuePosition Int

  estimatedWait Int?
  status        String @default("pending")

  diagnosis    String?
  prescription String?

  patient User   @relation(fields: [patientId], references: [id])
  doctor  Doctor @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
}

model DoctorLeave {
  id        String   @id @default(uuid())
  doctorId  String
  leaveDate DateTime

  doctor Doctor @relation(fields: [doctorId], references: [id])
}

model Review {
  id String @id @default(uuid())

  rating  Int
  comment String?

  patientId String
  doctorId  String

  patient User   @relation(fields: [patientId], references: [id])
  doctor  Doctor @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
}
